<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Style x:Key="common-cursor-hand-sm"
        TargetType="TextBlock"
        BasedOn="{StaticResource common-font-sm}">

        <Setter Property="Cursor" Value="Hand"/>

    </Style>

    <Style x:Key="common-cursor-hand-md"
        TargetType="TextBlock"
        BasedOn="{StaticResource common-font-md}">

        <Setter Property="Cursor" Value="Hand"/>

    </Style>

    <Style x:Key="common-cursor-hand-lg"
        TargetType="TextBlock"
        BasedOn="{StaticResource common-font-lg}">

        <Setter Property="Cursor" Value="Hand"/>

    </Style>

    <Style x:Key="common-cursor-hand-xl"
       TargetType="TextBlock"
       BasedOn="{StaticResource common-font-xl}">

        <Setter Property="Cursor" Value="Hand"/>

    </Style>

</ResourceDictionary>