<Window x:Class="roomservice.presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:roomservice.presentation"
        mc:Ignorable="d"
        Background="#F5F5F5"
        Title="Room Service" Width="1920" Height="1080">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border 
        Grid.Row="1" 
        Grid.Column="1" 
        CornerRadius="20"
        Padding="20">


            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <Border 
                Grid.Column="0" 
                Grid.Row="0" 
                Background="White"
                CornerRadius="20"
                BorderBrush="LightGray"
                BorderThickness="0 0 2 0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid 
                        Grid.Column="0"
                        Grid.Row="0" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        >
                            <StackPanel>
                                <TextBlock 
                                Text="Acesso"
                                FontSize="24"
                                Cursor="Hand"
                                TextAlignment="Center"
                                TextWrapping="Wrap"/>

                                <Border BorderBrush="Gray"
                                    BorderThickness="0 1 0 0" CornerRadius="10" Padding="10 0 10 0">
                                    <TextBlock 
                                    Text="Room Service"
                                    FontSize="24"
                                    Cursor="Hand"
                                    TextWrapping="Wrap"
                                    />
                                </Border>


                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" HorizontalAlignment="Center">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Google" Width="30" Height="30" Margin="5" />
                                <materialDesign:PackIcon Kind="Facebook" Width="30" Height="30" Margin="5" />
                                <materialDesign:PackIcon Kind="Twitter" Width="30" Height="30" Margin="5" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                                <TextBlock 
                                Text="ou cadastrar se"
                                FontSize="14"       
                                Style="{StaticResource common-cursor-hand-xl}"/>
                            </StackPanel>

                        </Grid>

                    </Grid>

                </Border>

                <Border Grid.Column="1" Background="White" Margin="10 0 0 0" CornerRadius="20">

                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
