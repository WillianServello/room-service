<Window x:Class="roomservice.presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:roomservice.presentation"
        mc:Ignorable="d"
        Background="#F5F5F5"
        Title="Room Service" Width="1920" Height="1080">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="1" Grid.Row="1" 
                Style="{StaticResource common-padding-cornerradius-md}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <Border Grid.Column="0" Grid.Row="0" 
                    Style="{StaticResource common-box-white}">
                    

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Column="0" Grid.Row="0" 
                        Style="{StaticResource common-display-center}">
                            
                            <StackPanel>
                                <TextBlock Text="Acesso"
                                    Style="{StaticResource cm-txt-center-3xl}"/>

                                <Border BorderBrush="Gray"
                                    BorderThickness="0 1 0 0" CornerRadius="10" Padding="10 0 10 0">
                                    
                                    <TextBlock Text="Room Service"
                                        Style="{StaticResource cm-cursor-hand-3xl}"/>
                                    
                                </Border>


                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="0" Grid.Row="1" 
                              Style="{StaticResource common-hg-center}">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" 
                                        Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Google" Width="30" Height="30" Margin="5" />
                                <materialDesign:PackIcon Kind="Facebook" Width="30" Height="30" Margin="5" />
                                <materialDesign:PackIcon Kind="Twitter" Width="30" Height="30" Margin="5" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0"
                                Style="{StaticResource common-hs-center}">
                                
                                <TextBlock Text="ou cadastrar se"
                                     Style="{StaticResource common-cursor-hand-xl}"/>
                            </StackPanel>

                        </Grid>

                    </Grid>

                </Border>

                <Border Grid.Column="1" Grid.Row="0" 
                        Style="{StaticResource common-box-white}" Margin="10 0 0 0">

                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
